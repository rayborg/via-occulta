---
import type { ShowcasePage } from '../data/showcase';
import { selectShowcasePreview } from '../data/showcase';
import SpriteStrip from './SpriteStrip.astro';
import { withBase } from '../paths';

type Props = {
  page: ShowcasePage;
  href: string;
};

const { page, href } = Astro.props;
const previewEntries = selectShowcasePreview(page.entries);
const typeLabel = page.kind === 'monster' ? 'Bestiary dossier' : 'Character dossier';
const countLabel = page.kind === 'monster' ? 'sightings logged' : 'profiles logged';
const largestPreviewEdge = previewEntries.length > 0 ? Math.max(...previewEntries.map((entry) => Math.max(entry.width, entry.height))) : 0;
const previewScale = page.kind === 'character' || largestPreviewEdge <= 45 ? 3 : 2;
const previewSize = page.kind === 'monster'
  ? largestPreviewEdge >= 80
    ? 'huge'
    : largestPreviewEdge >= 64
      ? 'large'
      : largestPreviewEdge >= 48
        ? 'medium'
        : 'small'
  : 'standard';
---

<a class="showcase-card panel" href={withBase(href)} data-kind={page.kind} data-preview-size={previewSize}>
  <div class="showcase-card__art">
    <SpriteStrip entries={previewEntries} scale={previewScale} label={`${page.title} dossier preview`} density="compact" showLabels={false} rhythm="subtle" />
  </div>
  <div class="showcase-card__copy">
    <p class="card-kicker">{typeLabel}</p>
    <h3>{page.title}</h3>
    <p>{page.summary}</p>
    <p class="card-meta">{page.entries.length} {countLabel}</p>
    <span class="showcase-card__cta">Open dossier</span>
  </div>
</a>
