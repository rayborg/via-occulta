---
import type { ShowcasePage } from '../data/showcase';
import SpriteStrip from './SpriteStrip.astro';
import { withBase } from '../paths';

type Props = {
  page: ShowcasePage;
  href: string;
};

const { page, href } = Astro.props;
const previewEntries = page.entries.slice(0, 5);
const typeLabel = page.kind === 'monster' ? 'Bestiary family' : 'Roster group';
---

<a class="showcase-card jrpg-window" href={withBase(href)}>
  <div class="showcase-card__art">
    <SpriteStrip entries={previewEntries} label={`${page.title} representative sprites`} density="compact" />
  </div>
  <div class="showcase-card__copy">
    <p class="card-kicker">{typeLabel}</p>
    <h3>{page.title}</h3>
    <p>{page.summary}</p>
    <p class="card-meta">{page.entries.length} {page.entries.length === 1 ? 'form' : 'forms'} logged</p>
  </div>
</a>
