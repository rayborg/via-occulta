---
import SpriteImage from './SpriteImage.astro';
import type { FlatEntry } from '../data/showcase';

type SpriteScale = 2 | 3 | 4;

type Props = {
  entries: FlatEntry[];
  scale?: SpriteScale;
  label?: string;
  density?: 'compact' | 'regular' | 'hero';
  loading?: 'eager' | 'lazy';
  showLabels?: boolean;
  rhythm?: 'none' | 'subtle';
};

const {
  entries,
  scale = 3,
  label = 'Sprite lineup',
  density = 'regular',
  loading = 'lazy',
  showLabels = true,
  rhythm = 'none'
} = Astro.props;
---

<div class:list={["sprite-strip", `sprite-strip--${density}`]} role="list" aria-label={label} data-scale={`${scale}x`}>
  {entries.map((entry, index) => (
    <figure class="sprite-strip__slot" role="listitem" data-cadence={rhythm === 'subtle' ? index % 4 : undefined}>
      <div class="sprite-strip__stage">
        <SpriteImage entry={entry} scale={scale} loading={loading} />
      </div>
      {showLabels && <figcaption>{entry.label}</figcaption>}
    </figure>
  ))}
</div>
