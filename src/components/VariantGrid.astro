---
import type { FlatEntry } from '../data/showcase';

type Props = {
  entries: FlatEntry[];
};

const { entries } = Astro.props;
---

<div class="variant-grid">
  {entries.map((entry) => (
    <article class="variant-card">
      <div class="variant-art"><img src={entry.image} alt={entry.label} loading="lazy" /></div>
      <h3>{entry.label}</h3>
    </article>
  ))}
</div>
