---
import SpriteStrip from '../../components/SpriteStrip.astro';
import VariantGrid from '../../components/VariantGrid.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { monsterPages, selectShowcasePreview } from '../../data/showcase';
import { withBase } from '../../paths';
import type { ShowcasePage } from '../../data/showcase';

type Props = {
  page: ShowcasePage;
};

export function getStaticPaths() {
  return monsterPages.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

const { page } = Astro.props;
const primaryThread = page.tags[0] ?? 'Road-Bound';
const largestNativeEdge = Math.max(...page.entries.map((entry) => Math.max(entry.width, entry.height)));
const galleryScale: 2 | 3 | 4 = page.entries.length === 1 && largestNativeEdge <= 40 ? 4 : largestNativeEdge > 56 ? 2 : 3;
const dossierPreview = selectShowcasePreview(page.entries, 4);
---

<BaseLayout title={`${page.title} | Via Occulta Monsters`} description={page.summary}>
  <section class="page-hero dossier-hero-section">
    <div class="shell dossier-hero">
      <div class="dossier-hero__copy">
        <a class="breadcrumb" href={withBase('/monsters')}>Monsters</a>
        <p class="eyebrow">Bestiary dossier</p>
        <h1>{page.title}</h1>
        <p>{page.summary}</p>
        <div class="tag-row">
          {page.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </div>
      <aside class="dossier-plate dossier-plate--threat panel" aria-label={`${page.title} threat plate`}>
        <div class="dossier-plate__header">
          <span>Threat plate</span>
          <strong>{primaryThread}</strong>
        </div>
        <SpriteStrip entries={dossierPreview} label={`${page.title} threat plate`} scale={galleryScale} density="hero" loading="eager" showLabels={false} rhythm="subtle" />
        <div class="dossier-plate__footer">
          <span>{page.entries.length} sightings logged</span>
          <span>Encounter role: Road-Bound evidence</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section-tight">
    <div class="shell dossier-layout">
      <article class="dossier-copy panel">
        <p class="eyebrow">Bestiary reading</p>
        <h2>{page.title} pressure in the hidden-road collapse</h2>
        {page.description.map((paragraph) => <p>{paragraph}</p>)}
      </article>
      <aside class="dossier-facts panel" aria-label={`${page.title} threat notes`}>
        <p class="eyebrow">Threat notes</p>
        <dl>
          <div>
            <dt>Primary sign</dt>
            <dd>{primaryThread}</dd>
          </div>
          <div>
            <dt>Encounter role</dt>
            <dd>Road-bound pressure, dungeon ecology, displaced guardian, or proof that a route has failed.</dd>
          </div>
          <div>
            <dt>Sightings logged</dt>
            <dd>{page.entries.length}</dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Sighting record</p>
      <h2>Silhouettes logged as evidence of route failure.</h2>
      <VariantGrid entries={page.entries} label={`${page.title} bestiary sightings`} scale={galleryScale} />
    </div>
  </section>
</BaseLayout>
