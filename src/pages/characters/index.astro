---
import ShowcaseCard from '../../components/ShowcaseCard.astro';
import SpriteStrip from '../../components/SpriteStrip.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { characterPages } from '../../data/showcase';
import type { FlatEntry } from '../../data/showcase';

const entryCount = characterPages.reduce((total, page) => total + page.entries.length, 0);
const characterEntries = characterPages.flatMap((page) => page.entries);
const characterRibbon = ['swordsman-l9', 'priest', 'tower-reader']
  .map((slug) => characterEntries.find((entry) => entry.slug === slug))
  .filter((entry): entry is FlatEntry => Boolean(entry))
  .slice(0, 3);
---

<BaseLayout
  title="Characters | Via Occulta"
  description="Via Occulta character dossiers for shriners, adventurers, guild workers, townsfolk, mages, trainers, and social interiors."
>
  <section class="page-hero codex-hero-section">
    <div class="shell codex-hero">
      <div class="codex-hero__copy">
        <p class="eyebrow">Character codex</p>
        <h1>People who keep the hidden-road world legible.</h1>
        <p>
          Via Occulta is not carried by heroes alone. Shrine orders, guild laborers, market citizens,
          tavern watchers, under-town survivors, and training-yard roles all explain how a town survives
          when the map beneath it changes.
        </p>
        <div class="pill-row">
          <span class="pill">{characterPages.length} dossier groups</span>
          <span class="pill">{entryCount} logged profiles</span>
          <span class="pill">Institutions over chosen ones</span>
        </div>
      </div>
      <aside class="codex-slate panel" aria-label="Character codex preview">
        <div class="codex-slate__header">
          <span>Personnel register</span>
          <strong>Shrine / Guild / Road</strong>
        </div>
        <SpriteStrip entries={characterRibbon} scale={2} label="Character role preview" density="hero" loading="eager" showLabels={false} />
        <div class="codex-slate__note">
          <p>Readable silhouettes are treated as field identities: what job they do, what room they belong in, and how they keep the road-world functioning.</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div>
        <p class="eyebrow">World role</p>
        <h2>Not only heroes. Also institutions.</h2>
      </div>
      <div class="prose">
        <p>
          Via Occulta depends on social bodies as much as combat bodies. A priest, trader, herbalist, smith, reader, or tavern patron can carry as much world logic as an armored adventurer.
        </p>
        <p>
          These groups make the setting feel inhabited: a world of people preparing, arguing, repairing, teaching, watching, and surviving while the roads beneath them change.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Dossiers</p>
      <h2>Personnel files from a failing map.</h2>
      <div class="showcase-list">
        {characterPages.map((page) => <ShowcaseCard page={page} href={`characters/${page.slug}`} />)}
      </div>
    </div>
  </section>
</BaseLayout>
