---
import SpriteStrip from '../../components/SpriteStrip.astro';
import VariantGrid from '../../components/VariantGrid.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { characterPages, selectShowcasePreview } from '../../data/showcase';
import { withBase } from '../../paths';
import type { ShowcasePage } from '../../data/showcase';

type Props = {
  page: ShowcasePage;
};

export function getStaticPaths() {
  return characterPages.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

const { page } = Astro.props;
const primaryThread = page.tags[0] ?? 'Shared World';
const largestNativeEdge = Math.max(...page.entries.map((entry) => Math.max(entry.width, entry.height)));
const galleryScale: 2 | 3 | 4 = page.entries.length === 1 && largestNativeEdge <= 40 ? 4 : largestNativeEdge > 56 ? 2 : 3;
const dossierPreview = selectShowcasePreview(page.entries, 4);
---

<BaseLayout title={`${page.title} | Via Occulta Characters`} description={page.summary}>
  <section class="page-hero dossier-hero-section">
    <div class="shell dossier-hero">
      <div class="dossier-hero__copy">
        <a class="breadcrumb" href={withBase('/characters')}>Characters</a>
        <p class="eyebrow">Character dossier</p>
        <h1>{page.title}</h1>
        <p>{page.summary}</p>
        <div class="tag-row">
          {page.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </div>
      <aside class="dossier-plate dossier-plate--character panel" aria-label={`${page.title} profile plate`}>
        <div class="dossier-plate__header">
          <span>Personnel plate</span>
          <strong>{primaryThread}</strong>
        </div>
        <SpriteStrip entries={dossierPreview} label={`${page.title} profile plate`} scale={galleryScale} density="hero" loading="eager" showLabels={false} rhythm="subtle" />
        <div class="dossier-plate__footer">
          <span>{page.entries.length} profiles logged</span>
          <span>World function: {primaryThread}</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section-tight">
    <div class="shell dossier-layout">
      <article class="dossier-copy panel">
        <p class="eyebrow">Codex reading</p>
        <h2>{page.title} as a role in the hidden-road world</h2>
        {page.description.map((paragraph) => <p>{paragraph}</p>)}
      </article>
      <aside class="dossier-facts panel" aria-label={`${page.title} field notes`}>
        <p class="eyebrow">Field notes</p>
        <dl>
          <div>
            <dt>Primary thread</dt>
            <dd>{primaryThread}</dd>
          </div>
          <div>
            <dt>World function</dt>
            <dd>Faction, craft, town, road, or expedition work that keeps the hidden-road world legible.</dd>
          </div>
          <div>
            <dt>Profiles logged</dt>
            <dd>{page.entries.length}</dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <section class="section character-lineup-section">
    <div class="shell">
      <p class="eyebrow">Lineup record</p>
      <h2>Silhouettes logged as readable field identities.</h2>
      <VariantGrid entries={page.entries} label={`${page.title} character profiles`} scale={galleryScale} />
    </div>
  </section>
</BaseLayout>
