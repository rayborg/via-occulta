---
import BaseLayout from '../layouts/BaseLayout.astro';

const gameLines = [
  {
    name: 'Tenebrio',
    kicker: 'Shriner exploration',
    role: 'Discovery, mapping, shrine rites, hidden routes, disguise, and transformation.',
    fantasy: 'You are weak, but you know the rites.',
    contributes: ['Map fragments', 'Shrine keys', 'Monster-form knowledge', 'Occult warnings', 'Route unlocks']
  },
  {
    name: 'Luciphilus',
    kicker: 'Adventurer RPG',
    role: 'Dungeon expeditions, battle-screen pressure, relic recovery, monsters, and crystal-era conflict.',
    fantasy: 'You carry the light into the road after someone else has found it.',
    contributes: ['Cleared routes', 'Boss relics', 'Monster parts', 'Recovered weapons', 'Proof an area can be rebuilt']
  },
  {
    name: 'Opiphilus',
    kicker: 'Crafter and guild work',
    role: 'Workshops, town interiors, trade orders, ritual support, repairs, and restoration projects.',
    fantasy: 'You make the tools that let the town endure the abyss.',
    contributes: ['Road lanterns', 'Shrine repair kits', 'Guild orders', 'Town upgrades', 'Market circulation']
  }
];

const handoff = [
  'Tenebrio maps the changed route beneath Mistfall Chapel.',
  'Luciphilus clears the Wraith of the Drowned Gate in the Chapel Undercrypt.',
  'Opiphilus restores the Guild Hearth forge and repairs the shrine bell casing.',
  'Greybell reopens the Old Crystal Gate and the next region becomes reachable.'
];
---

<BaseLayout
  title="Games | Via Occulta"
  description="The three linked Via Occulta game lines: Tenebrio discovers, Luciphilus fights, and Opiphilus builds."
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Three linked game lines</p>
      <h1>Discovery, battle, and craft share one wounded map.</h1>
      <p>
        Via Occulta is not one generic online role with different skins. Tenebrio, Luciphilus, and
        Opiphilus are distinct ways of serving the same hidden-road world: find what vanished, survive
        what guards it, and rebuild the civic systems that keep it open.
      </p>
      <div class="pill-row">
        <span class="pill">Tenebrio discovers</span>
        <span class="pill">Luciphilus fights</span>
        <span class="pill">Opiphilus builds</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Playable lenses</p>
      <h2>The world changes when each role completes its part.</h2>
      <div class="role-grid">
        {gameLines.map((line) => (
          <article class="role-card panel">
            <p class="card-kicker">{line.kicker}</p>
            <h3>{line.name}</h3>
            <p>{line.role}</p>
            <p class="role-card__quote">{line.fantasy}</p>
            <h4>Contributes</h4>
            <ul>
              {line.contributes.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div class="summary-panel panel">
        <p class="eyebrow">Core loop</p>
        <h3>Find the road. Survive the road. Rebuild the road.</h3>
        <ul>
          <li>Tenebrio discovers a hidden shrine route, forbidden door, monster disguise, or map fragment.</li>
          <li>Luciphilus clears the combat threat inside the revealed dungeon, ruin, cave, or under-route.</li>
          <li>Opiphilus builds the tools, repairs, recipes, charms, and guild infrastructure needed to hold it open.</li>
          <li>The world unlocks a new room, road, recipe, project, or story chapter.</li>
        </ul>
      </div>
      <div class="prose">
        <p>
          Shared towns, guild spaces, markets, and restoration projects give the world continuity,
          while dungeons, story rooms, shrine trials, and key battles stay focused and readable.
        </p>
        <p>
          This is why the setting is built around infrastructure instead of conquest. A route is not saved when a monster dies. It is saved when the shrine remembers the rite, the adventurers prove the danger can be survived, and the guild can make the repaired key, lantern, bell, or charter work again.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Opening handoff</p>
      <h2>The first chapter proves the whole shared-world promise.</h2>
      <div class="chapter-flow">
        {handoff.map((step, index) => (
          <article class="chapter-step panel" data-step={`0${index + 1}`}>
            <h3>{index === 0 ? 'Rite' : index === 1 ? 'Expedition' : index === 2 ? 'Repair' : 'Unlock'}</h3>
            <p>{step}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
