---
import BaseLayout from '../layouts/BaseLayout.astro';

const gameLines = [
  {
    name: 'Tenebrio',
    kicker: 'Shriner scout',
    role: 'A weak shriner maps forbidden routes and survives through rites, maps, disguise, transformation, and forbidden knowledge.',
    cast: 'Main candidates: base male unarmed and base female unarmed, with sword variants reserved for later defensive or disguise-capable states. Support: priests, monks, shrine keepers, pilgrims, road-bound spirits, disguised monsters, and cursed locals.',
    fantasy: 'You are weak, but you know the rites.',
    contributes: ['Map fragments', 'Shrine keys', 'Disguise rites', 'Occult warnings', 'Route unlocks']
  },
  {
    name: 'Luciphilus',
    kicker: 'Paid adventurer escort',
    role: 'An adventurer, escort, and monster-clearer accepts contracts, clears threats, escorts fragile travelers, fights bosses, and recovers relics.',
    cast: 'Main candidate: the Swordsman line as the clearest active player hero. Support: guards, fighters, archers, expedition members, lantern-company adventurers, monster hunters, mages, and dungeon parties.',
    fantasy: 'You carry the light into the road after someone else has found it.',
    contributes: ['Cleared routes', 'Boss relics', 'Monster parts', 'Recovered weapons', 'Proof an area can be rebuilt']
  },
  {
    name: 'Opiphilus',
    kicker: 'Guild crafter / trader',
    role: 'A guild worker, crafter, or trade traveler is fragile outside settlements, posts escort requests, travels for shops and craft jobs, and rebuilds civilization.',
    cast: 'Main candidates: Smith, Herbalist, Priest / ritual support, Guild Mage, Monk, and Glassblower / Blacksmith worker where animation supports it. Support: shopkeepers, traders, market workers, guild clerks, blacksmiths, herbalists, glassblowers, villagers, and escorted clients.',
    fantasy: 'You make the tools that let the town endure the abyss.',
    contributes: ['Road lanterns', 'Shrine repair kits', 'Guild orders', 'Town upgrades', 'Market circulation']
  }
];

const handoff = [
  'Tenebrio recovers a map fragment from a room that appears only under a Road-Bound disguise.',
  'Luciphilus clears the Wraith of the Drowned Gate and brings back a relic-crystal shard.',
  'Opiphilus combines ghost silk, iron, lantern glass, and crystal dust into the first Road Lantern.',
  'Greybell repairs the bell housing, issues a road charter, and reveals the Old Crystal Gate.'
];

const forces = [
  {
    name: 'Shrine Orders',
    claim: 'Rites, names, bells, and disguise customs decide who the road recognizes.'
  },
  {
    name: 'Lantern Companies',
    claim: 'Expeditions prove whether a recovered route can actually be survived.'
  },
  {
    name: 'Guild Houses',
    claim: 'Workshops turn relics, glass, iron, and charters into civic infrastructure.'
  },
  {
    name: 'Crystal Courts',
    claim: 'Old gates, archives, checkpoints, and inscriptions still enforce failed road law.'
  },
  {
    name: 'Road-Bound',
    claim: 'Some monsters are displaced guardians, cursed citizens, or territorial dead, not simple invaders.'
  }
];
---

<BaseLayout
  title="Games | Via Occulta"
  description="The three linked Via Occulta game lines: Tenebrio discovers, Luciphilus fights, and Opiphilus builds."
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Three linked game lines</p>
      <h1>Discovery, battle, and craft share one wounded map.</h1>
      <p>
        Via Occulta is not one generic online role with different skins. Tenebrio, Luciphilus, and
        Opiphilus are distinct ways of serving the same hidden-road world: find what vanished, survive
        what guards it, and rebuild the civic systems that keep it open.
      </p>
      <div class="pill-row">
        <span class="pill">Tenebrio discovers</span>
        <span class="pill">Luciphilus fights</span>
        <span class="pill">Opiphilus builds</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Playable lenses</p>
      <h2>The world changes when each role completes its part.</h2>
      <div class="role-grid">
        {gameLines.map((line) => (
          <article class="role-card panel">
            <p class="card-kicker">{line.kicker}</p>
            <h3>{line.name}</h3>
            <p>{line.role}</p>
            <p class="role-card__quote">{line.fantasy}</p>
            <h4>Cast anchor</h4>
            <p>{line.cast}</p>
            <h4>Contributes</h4>
            <ul>
              {line.contributes.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tight">
    <div class="shell">
      <p class="eyebrow">One road, five claims</p>
      <h2>The route is never just a dungeon entrance.</h2>
      <div class="force-grid">
        {forces.map((force) => (
          <article class="info-card panel">
            <h3>{force.name}</h3>
            <p>{force.claim}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div class="summary-panel panel">
        <p class="eyebrow">Core loop</p>
        <h3>Find the road. Survive the road. Rebuild the road.</h3>
        <ul>
          <li>Tenebrio discovers a hidden shrine route, forbidden door, monster disguise, or map fragment.</li>
          <li>Luciphilus clears the combat threat inside the revealed dungeon, ruin, cave, or under-route.</li>
          <li>Opiphilus builds the tools, repairs, recipes, charms, and guild infrastructure needed to hold it open.</li>
          <li>The world unlocks a new room, road, recipe, project, or story chapter.</li>
        </ul>
      </div>
      <div class="prose">
        <p>
          Shared towns, guild spaces, markets, and restoration projects give the world continuity,
          while dungeons, story rooms, shrine trials, and key battles stay focused and readable.
        </p>
        <p>
          This is why the setting is built around infrastructure instead of conquest. A route is not saved when a monster dies. It is saved when the shrine remembers the rite, the adventurers prove the danger can be survived, and the guild can make the repaired key, lantern, bell, or charter work again.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Opening handoff</p>
      <h2>The first chapter proves the whole shared-world promise.</h2>
      <div class="chapter-flow">
        {handoff.map((step, index) => (
          <article class="chapter-step panel" data-step={`0${index + 1}`}>
            <h3>{index === 0 ? 'Rite' : index === 1 ? 'Expedition' : index === 2 ? 'Repair' : 'Unlock'}</h3>
            <p>{step}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
