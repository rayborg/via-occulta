---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../paths';

const areas = [
  {
    name: 'Greybell Shrine',
    type: 'Shrine-town hub',
    copy: 'A road-bell plaza where the shrine still swings its bell without sound. Pilgrims gather here because every road beyond town has become suspect.'
  },
  {
    name: 'The Broken Road',
    type: 'Road and forest approach',
    copy: 'A path of grass, stones, black trees, bridges, and white fog. It teaches the first rule of the Verge: a mapped road can still betray you.'
  },
  {
    name: 'Mistfall Chapel',
    type: 'Cursed chapel and shrine ruin',
    copy: 'A drowned chapel ruin where a hidden room appears only to the correctly disguised. Its map fragment proves the old routes are changing.'
  },
  {
    name: 'The Underwell',
    type: 'Sewer, cave, and under-town route',
    copy: 'A damp under-town channel where wells, sewers, cave stone, vermin, alchemy, and old roadwork cross beneath Greybell.'
  },
  {
    name: 'The Chapel Undercrypt',
    type: 'Occult dungeon',
    copy: 'The grave-road below Mistfall: traps, cursed props, crystal locks, and the Wraith of the Drowned Gate waiting behind the recovered route.'
  },
  {
    name: 'The Guild Hearth',
    type: 'Guild hall and workshop cluster',
    copy: 'Forge, herbalist bench, glasswork, ledgers, and order boards. Here ghost silk, iron, lantern glass, and crystal dust become a Road Lantern.'
  },
  {
    name: 'The Old Crystal Gate',
    type: 'Ruin threshold',
    copy: 'A ruined court threshold of crystal-law inscriptions and sealed authority. When the bell rings once, the gate becomes visible again.'
  }
];

const arcSteps = [
  'Greybell Shrine stops ringing, and every charted route beyond town becomes unreliable.',
  'Tenebrio enters Mistfall Chapel in a road-bound disguise and recovers the changed map fragment.',
  'Luciphilus carries the fragment into the Chapel Undercrypt and defeats the Wraith of the Drowned Gate.',
  'Opiphilus repairs the bell housing and crafts the first Road Lantern at the Guild Hearth.',
  'The bell rings once. The Broken Road steadies long enough to reveal the Old Crystal Gate.'
];
---

<BaseLayout
  title="The Pilgrim Verge | Via Occulta"
  description="The first Via Occulta region: Greybell Shrine, The Broken Road, Mistfall Chapel, The Underwell, The Chapel Undercrypt, The Guild Hearth, and The Old Crystal Gate."
>
  <section class="page-hero">
    <div class="shell">
      <a class="breadcrumb" href={withBase('/world')}>World</a>
      <p class="eyebrow">First region</p>
      <h1>The Pilgrim Verge</h1>
      <p>
        The Pilgrim Verge is the first cursed pilgrimage route: a shrine-town frontier of road bells,
        chapel ruins, under-town channels, guild workshops, market thresholds, and one old Crystal Court
        gate that should have stayed sealed.
      </p>
      <div class="pill-row">
        <span class="pill">Greybell Shrine</span>
        <span class="pill">Mistfall Chapel</span>
        <span class="pill">The Guild Hearth</span>
        <span class="pill">The Old Crystal Gate</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div class="summary-panel panel">
        <p class="eyebrow">Opening arc</p>
        <h3>The Bell That Forgot the Road</h3>
        <ul>
          {arcSteps.map((step) => <li>{step}</li>)}
        </ul>
      </div>
      <div class="prose">
        <p>
          The Verge stays close to local life: a place of old bells, failed crossings, practical guild
          work, and thresholds that do not open because the player is chosen. They open because rites,
          proof, materials, and labor line up again.
        </p>
        <p>
          The region feels complete because Via Occulta is not about size first. It is about route
          failure, local institutions, hidden infrastructure, and the recovery of a world one shrine,
          workshop, and threshold at a time.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Region map</p>
      <h2>Seven places around the first failing road.</h2>
      <div class="card-grid">
        {areas.map((area) => (
          <article class="info-card panel">
            <p class="card-kicker">{area.type}</p>
            <h3>{area.name}</h3>
            <p>{area.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
