---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../paths';

const gameLines = [
  {
    name: 'Tenebrio',
    action: 'Discovers',
    copy: 'A weak shriner maps forbidden routes, survives by rites and disguise, and brings back proof that a road still exists.',
    payoff: 'You are weak, but you know the rites.'
  },
  {
    name: 'Luciphilus',
    action: 'Fights',
    copy: 'An expedition party carries light into the revealed dungeon, clears the threat, and recovers relics that make repair possible.',
    payoff: 'You carry the light after someone else found the door.'
  },
  {
    name: 'Opiphilus',
    action: 'Builds',
    copy: 'Guild workers craft lanterns, fulfill orders, reopen workshops, and turn danger into civic infrastructure.',
    payoff: 'You make the tools that let the town endure.'
  }
];

const regionHighlights = [
  'Shrine-Town Hub',
  'Road and Forest',
  'Chapel Ruins',
  'Cave and Sewer',
  'Dungeon Rooms',
  'Guild Hall and Workshops',
  'Market Square',
  'Ruins Gate'
];

const openingBeats = [
  {
    step: '01',
    title: 'The Map Fails',
    copy: 'The first shrine road slips out of ordinary geography. Every mapped road beyond town becomes unreliable.'
  },
  {
    step: '02',
    title: 'Chapel Ruins Reveal A Room',
    copy: 'A Tenebrio shriner enters the cursed chapel and recovers a map fragment from a room that only appears under disguise.'
  },
  {
    step: '03',
    title: 'Dungeon Rooms Answer',
    copy: 'Luciphilus carries the fragment into the dungeon rooms below and clears the first route threat.'
  },
  {
    step: '04',
    title: 'The Route Is Marked',
    copy: 'Opiphilus turns recovered relics, glass, iron, and craft labor into route hardware. A ruins gate becomes reachable.'
  }
];
---

<BaseLayout title="Via Occulta | A 1-bit occult shared-world JRPG">
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">First Route / Shrine-Town Hub</p>
        <h1>The map is wrong. The hidden road is open.</h1>
        <p class="lede">
          Via Occulta is a 1-bit occult JRPG about finding forbidden routes, surviving the rooms behind them,
          and restoring the town with proof brought back alive.
        </p>
        <div class="hero-proof" aria-label="Core promise">
          <span>Read the map</span>
          <span>Enter the chapel</span>
          <span>Bring proof home</span>
        </div>
        <div class="hero-actions" aria-label="Primary paths">
          <a class="button button--primary" href={withBase('/world')}>Enter the world</a>
          <a class="button" href={withBase('/games')}>See the game loop</a>
        </div>
      </div>
      <aside class="cinematic-frame panel" aria-label="Opening hidden-road omen">
        <div class="field-screen">
          <div class="field-screen__hud">
            <span>First Route</span>
            <span>Opening omen</span>
          </div>
          <figure class="onebit-art onebit-art--hero">
            <div class="onebit-art__viewport">
              <img
                class="onebit-art__image"
                src={withBase('/art/coverART_BW.png')}
                alt="Black-and-white Via Occulta cover artwork showing the occult pilgrimage world"
                width="1619"
                height="971"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            </div>
            <figcaption>The road remembers those who know the rite.</figcaption>
          </figure>
          <div class="field-screen__caption">
            <p class="eyebrow">Opening route</p>
            <h2>A shrine road opens where the map says nothing.</h2>
            <p>
              Quest: enter the chapel ruins, recover the road fragment, survive the dungeon rooms,
              and bring proof back before the town forgets how to open the route.
            </p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section-tight">
    <div class="shell">
      <p class="eyebrow">Opening route</p>
      <h2>First Route: The Road That Should Not Open.</h2>
      <div class="chapter-flow">
        {openingBeats.map((beat) => (
          <article class="chapter-step panel" data-step={beat.step}>
            <h3>{beat.title}</h3>
            <p>{beat.copy}</p>
          </article>
        ))}
      </div>
      <div class="link-row">
        <a class="text-link" href={withBase('/world/first-route')}>Visit the first route</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Game promise</p>
      <h2>Three games share one wounded map.</h2>
      <div class="game-lineup">
        {gameLines.map((line) => (
          <article class="role-card panel">
            <p class="card-kicker">{line.action}</p>
            <h3>{line.name}</h3>
            <p>{line.copy}</p>
            <p class="role-card__quote">{line.payoff}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div>
        <p class="eyebrow">Story premise</p>
        <h2>The old roads no longer obey the rites.</h2>
      </div>
      <div class="prose">
        <p>
          The old roads were a living network of oaths, crystals, ritual locks, guild charters, crafted
          keys, road lanterns, and monster-bound disguises. Now crystals no longer hold their light,
          wells open into catacombs, and chapel doors lead to rooms that should not exist.
        </p>
        <p>
          The central fantasy is not chosen-one conquest. It is to find the hidden road, survive what
          guards it, bring back proof, and help the town remember how to use it.
        </p>
        <div class="link-row">
          <a class="text-link" href={withBase('/world')}>Read the world premise</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell region-showcase panel">
      <div class="region-showcase__copy">
        <p class="eyebrow">Opening region</p>
        <h2>A shrine-town frontier of chapels, wells, and wrong doors.</h2>
        <p>
          The first route starts small on purpose: a shrine-town hub, road and forest approach,
          chapel ruins, a cave and sewer under-route, guild halls, market rooms, and a ruins gate.
        </p>
        <a class="text-link" href={withBase('/world/first-route')}>Visit the first route</a>
      </div>
      <div class="region-showcase__places" aria-label="First route source-derived areas">
        {regionHighlights.map((area) => <span>{area}</span>)}
      </div>
    </div>
  </section>

</BaseLayout>
