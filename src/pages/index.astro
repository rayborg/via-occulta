---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShowcaseCard from '../components/ShowcaseCard.astro';
import SpriteStrip from '../components/SpriteStrip.astro';
import { homepageFeaturedCharacters, homepageFeaturedMonsters } from '../data/showcase';
import type { FlatEntry, ShowcasePage } from '../data/showcase';
import { withBase } from '../paths';

function requirePage(page: ShowcasePage | undefined, label: string): ShowcasePage {
  if (!page) throw new Error(`Missing homepage showcase page: ${label}`);
  return page;
}

const swordsmanPage = requirePage(homepageFeaturedCharacters.find((page) => page.slug === 'swordsman') ?? homepageFeaturedCharacters[0], 'swordsman');
const guildMagePage = requirePage(homepageFeaturedCharacters.find((page) => page.slug === 'guild-mage') ?? homepageFeaturedCharacters[1], 'guild-mage');
const blacksmithPage = requirePage(homepageFeaturedCharacters.find((page) => page.slug === 'blacksmith') ?? homepageFeaturedCharacters[2], 'blacksmith');
const goblinPage = requirePage(homepageFeaturedMonsters.find((page) => page.slug === 'goblin') ?? homepageFeaturedMonsters[0], 'goblin');
const ghostPage = requirePage(homepageFeaturedMonsters.find((page) => page.slug === 'ghost') ?? homepageFeaturedMonsters[1], 'ghost');
const heroEntries: FlatEntry[] = [
  swordsmanPage.entries[swordsmanPage.entries.length - 1],
  guildMagePage.entries[0],
  blacksmithPage.entries[0],
  goblinPage.entries[2] ?? goblinPage.entries[0],
  ghostPage.entries[1] ?? ghostPage.entries[0]
].filter((entry): entry is FlatEntry => Boolean(entry));
const featuredDossiers = [swordsmanPage, guildMagePage, ghostPage];
---

<BaseLayout title="Via Occulta | A 1-bit occult shared-world JRPG">
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">1-bit occult JRPG</p>
        <h1>Find the road. Survive what guards it. Bring it home.</h1>
        <p class="lede">
          Via Occulta is a calm, dark-fantasy world of shrine bells, hidden routes, dungeon expeditions,
          guild labor, and towns trying to remember how travel used to work.
        </p>
        <div class="hero-actions" aria-label="Primary paths">
          <a class="button button--primary" href={withBase('/world')}>Enter the world</a>
          <a class="button" href={withBase('/games')}>See the game loop</a>
        </div>
      </div>
      <aside class="hero-window panel" aria-label="Road-bound figures preview">
        <SpriteStrip entries={heroEntries} scale={3} label="Road-bound figures preview" density="hero" loading="eager" showLabels={false} />
        <div class="status-grid">
          <div><span>Mode</span><strong>Overhead JRPG</strong></div>
          <div><span>Palette</span><strong>1-bit Monochrome</strong></div>
          <div><span>Loop</span><strong>Find / Fight / Rebuild</strong></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Story premise</p>
      <h2>The old roads no longer obey the rites.</h2>
      <div class="three-up">
        <article class="info-card panel">
          <h3>The Viae Occultae</h3>
          <p>
            The hidden roads once linked shrines, caves, chapels, guild cellars, market doors, and
            sealed underways through a compact of rites, crystals, charters, and remembered names.
          </p>
        </article>
        <article class="info-card panel">
          <h3>The Quiet Collapse</h3>
          <p>
            The world is not ending in a single blaze. Its routes are being quietly rewritten.
            Towns wake to find wells opening into catacombs and chapel doors leading to rooms that
            should not exist.
          </p>
        </article>
        <article class="info-card panel">
          <h3>The Work Ahead</h3>
          <p>
            Tenebrio finds the road, Luciphilus survives what guards it, and Opiphilus turns the
            recovered fragments into something a town can use again.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div>
        <p class="eyebrow">Game structure</p>
        <h2>Three roles share one wounded map.</h2>
      </div>
      <div class="prose">
        <p>
          Tenebrio discovers what the map is hiding. Luciphilus enters the exposed route and clears
          the danger. Opiphilus turns the recovered proof into tools, repairs, charms, and guild work
          that make the road usable again.
        </p>
        <p>
          The fantasy is not chosen-one conquest. It is survival, proof, repair, and collective memory:
          a town becoming safer because different kinds of people did their part.
        </p>
        <div class="link-row">
          <a class="text-link" href={withBase('/games')}>Explore the three game lines</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div class="summary-panel panel">
        <p class="eyebrow">First region</p>
        <h3>The Pilgrim Verge</h3>
        <p>
          A compact shrine-town frontier: Greybell Shrine, The Broken Road, Mistfall Chapel, The
          Underwell, The Chapel Undercrypt, The Guild Hearth, and The Old Crystal Gate.
        </p>
      </div>
      <div class="prose">
        <p>
          The opening arc, <strong>The Bell That Forgot the Road</strong>, begins with a shrine bell
          falling silent. Roads beyond town become unreliable, a hidden route is found, a threat is
          cleared, and the guild rebuilds the object that lets the town remember how to travel.
        </p>
        <div class="link-row">
          <a class="text-link" href={withBase('/world/the-pilgrim-verge')}>Visit The Pilgrim Verge</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Field dossiers</p>
      <h2>A few faces from the road.</h2>
      <div class="card-grid">
        {featuredDossiers.map((page) => (
          <ShowcaseCard page={page} href={`${page.kind === 'monster' ? 'monsters' : 'characters'}/${page.slug}`} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
