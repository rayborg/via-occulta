---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShowcaseCard from '../components/ShowcaseCard.astro';
import SpriteImage from '../components/SpriteImage.astro';
import { homepageFeaturedCharacters, homepageFeaturedMonsters } from '../data/showcase';
import type { FlatEntry, ShowcasePage } from '../data/showcase';
import { withBase } from '../paths';

type HeroFigure = {
  entry: FlatEntry;
  role: string;
  detail: string;
  scale: 2 | 3;
  weight: 'anchor' | 'small' | 'normal';
};

function requirePage(page: ShowcasePage | undefined, label: string): ShowcasePage {
  if (!page) throw new Error(`Missing homepage showcase page: ${label}`);
  return page;
}

function requireEntry(entry: FlatEntry | undefined, label: string): FlatEntry {
  if (!entry) throw new Error(`Missing homepage showcase entry: ${label}`);
  return entry;
}

const swordsmanPage = requirePage(homepageFeaturedCharacters.find((page) => page.slug === 'swordsman') ?? homepageFeaturedCharacters[0], 'swordsman');
const guildMagePage = requirePage(homepageFeaturedCharacters.find((page) => page.slug === 'guild-mage') ?? homepageFeaturedCharacters[1], 'guild-mage');
const blacksmithPage = requirePage(homepageFeaturedCharacters.find((page) => page.slug === 'blacksmith') ?? homepageFeaturedCharacters[2], 'blacksmith');
const goblinPage = requirePage(homepageFeaturedMonsters.find((page) => page.slug === 'goblin') ?? homepageFeaturedMonsters[0], 'goblin');
const ghostPage = requirePage(homepageFeaturedMonsters.find((page) => page.slug === 'ghost') ?? homepageFeaturedMonsters[1], 'ghost');
const heroFigures: HeroFigure[] = [
  {
    entry: requireEntry(swordsmanPage.entries[swordsmanPage.entries.length - 1], 'swordsman veteran'),
    role: 'Lantern Company',
    detail: 'Luciphilus clears the opened road',
    scale: 2,
    weight: 'anchor'
  },
  {
    entry: requireEntry(guildMagePage.entries[0], 'guild mage'),
    role: 'Rite worker',
    detail: 'Opiphilus records the repair',
    scale: 2,
    weight: 'normal'
  },
  {
    entry: requireEntry(goblinPage.entries[2] ?? goblinPage.entries[0], 'road-bound goblin'),
    role: 'Road-bound',
    detail: 'A familiar threat bent by route failure',
    scale: 3,
    weight: 'small'
  },
  {
    entry: requireEntry(ghostPage.entries[1] ?? ghostPage.entries[0], 'Mistfall ghost'),
    role: 'Local dead',
    detail: 'Memory leaking through a failed rite',
    scale: 2,
    weight: 'small'
  },
  {
    entry: requireEntry(blacksmithPage.entries[0], 'blacksmith'),
    role: 'Bell repair',
    detail: 'A town worker turns proof into safety',
    scale: 2,
    weight: 'normal'
  }
];
const featuredDossiers = [swordsmanPage, guildMagePage, ghostPage];

const gameLines = [
  {
    name: 'Tenebrio',
    action: 'Discovers',
    copy: 'A weak shriner maps forbidden routes, survives by rites and disguise, and brings back proof that a road still exists.',
    payoff: 'You are weak, but you know the rites.'
  },
  {
    name: 'Luciphilus',
    action: 'Fights',
    copy: 'An expedition party carries light into the revealed dungeon, clears the threat, and recovers relics that make repair possible.',
    payoff: 'You carry the light after someone else found the door.'
  },
  {
    name: 'Opiphilus',
    action: 'Builds',
    copy: 'Guild workers craft lanterns, restore bells, fulfill orders, and turn danger into civic infrastructure.',
    payoff: 'You make the tools that let the town endure.'
  }
];

const regionHighlights = [
  'Greybell Shrine',
  'The Broken Road',
  'Mistfall Chapel',
  'The Underwell',
  'The Chapel Undercrypt',
  'The Guild Hearth',
  'The Old Crystal Gate'
];

const openingBeats = [
  {
    step: '01',
    title: 'The Bell Falls Silent',
    copy: 'Greybell Shrine still swings its road-bell, but no sound comes out. Every mapped road beyond town becomes unreliable.'
  },
  {
    step: '02',
    title: 'Mistfall Reveals A Room',
    copy: 'A Tenebrio shriner enters the cursed chapel and recovers a map fragment from a room that only appears under disguise.'
  },
  {
    step: '03',
    title: 'The Undercrypt Answers',
    copy: 'Luciphilus carries the fragment into the chapel undercrypt and clears the Wraith of the Drowned Gate.'
  },
  {
    step: '04',
    title: 'The Road Lantern Is Made',
    copy: 'Opiphilus repairs the bell housing with ghost silk, iron, lantern glass, and crystal dust. The Old Crystal Gate is revealed.'
  }
];
---

<BaseLayout title="Via Occulta | A 1-bit occult shared-world JRPG">
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">1-bit occult shared-world JRPG</p>
        <h1>Find the hidden road. Survive what guards it. Rebuild what it breaks.</h1>
        <p class="lede">
          Via Occulta is a tile-based dark-fantasy JRPG shared world where shriners discover forbidden routes,
          adventurers clear the dungeon pressure behind them, and guild crafters restore the town one bell,
          lantern, workshop, and threshold at a time.
        </p>
        <div class="hero-proof" aria-label="Core promise">
          <span>Tenebrio discovers</span>
          <span>Luciphilus fights</span>
          <span>Opiphilus builds</span>
        </div>
        <div class="hero-actions" aria-label="Primary paths">
          <a class="button button--primary" href={withBase('/world')}>Enter the world</a>
          <a class="button" href={withBase('/games')}>See the game loop</a>
        </div>
      </div>
      <aside class="cinematic-frame panel" aria-label="Greybell Shrine field screen">
        <div class="field-screen">
          <div class="field-screen__hud">
            <span>Greybell Shrine</span>
            <span>Route instability: active</span>
          </div>
          <div class="field-screen__map" role="list" aria-label="Via Occulta field figures">
            <span class="map-path map-path--main" aria-hidden="true"></span>
            <span class="map-path map-path--under" aria-hidden="true"></span>
            {heroFigures.map((figure, index) => (
              <figure class="field-figure" role="listitem" data-weight={figure.weight} data-lane={index}>
                <SpriteImage entry={figure.entry} scale={figure.scale} loading="eager" />
                <figcaption>
                  <strong>{figure.role}</strong>
                  <span>{figure.detail}</span>
                </figcaption>
              </figure>
            ))}
          </div>
          <div class="field-screen__caption">
            <p class="eyebrow">Opening crisis</p>
            <h2>The bell still swings. No sound comes out.</h2>
            <p>
              The Viae Occultae once opened through shrines, caves, drowned chapels, forest gates,
              market doors, guild cellars, and remembered names. Now the map is being quietly rerouted.
            </p>
          </div>
        </div>
        <div class="status-grid">
          <div><span>Format</span><strong>Overhead JRPG</strong></div>
          <div><span>Pressure</span><strong>Rerouted World</strong></div>
          <div><span>Loop</span><strong>Find / Fight / Rebuild</strong></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Game promise</p>
      <h2>Three games share one wounded map.</h2>
      <div class="game-lineup">
        {gameLines.map((line) => (
          <article class="role-card panel">
            <p class="card-kicker">{line.action}</p>
            <h3>{line.name}</h3>
            <p>{line.copy}</p>
            <p class="role-card__quote">{line.payoff}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div>
        <p class="eyebrow">Story premise</p>
        <h2>The old roads no longer obey the rites.</h2>
      </div>
      <div class="prose">
        <p>
          The old roads were a living network of oaths, crystals, ritual locks, guild charters, crafted
          keys, road lanterns, and monster-bound disguises. Now crystals no longer hold their light,
          wells open into catacombs, and chapel doors lead to rooms that should not exist.
        </p>
        <p>
          The central fantasy is not chosen-one conquest. It is to find the hidden road, survive what
          guards it, bring back proof, and help the town remember how to use it.
        </p>
        <div class="link-row">
          <a class="text-link" href={withBase('/world')}>Read the world premise</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell region-showcase panel">
      <div class="region-showcase__copy">
        <p class="eyebrow">Opening region</p>
        <h2>The Pilgrim Verge is built around what the current art can actually support.</h2>
        <p>
          The first region avoids unsupported castle promises and stays focused on shrine-town hubs,
          roads, forest approaches, cursed chapels, sewers, caves, occult dungeons, workshops, markets,
          and ruin thresholds.
        </p>
        <a class="text-link" href={withBase('/world/the-pilgrim-verge')}>Visit The Pilgrim Verge</a>
      </div>
      <div class="region-showcase__places" aria-label="Pilgrim Verge areas">
        {regionHighlights.map((area) => <span>{area}</span>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Opening chapter</p>
      <h2>The Bell That Forgot the Road.</h2>
      <div class="chapter-flow">
        {openingBeats.map((beat) => (
          <article class="chapter-step panel" data-step={beat.step}>
            <h3>{beat.title}</h3>
            <p>{beat.copy}</p>
          </article>
        ))}
      </div>
      <div class="link-row">
        <a class="text-link" href={withBase('/world/the-pilgrim-verge')}>Visit The Pilgrim Verge</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Codex dossiers</p>
      <h2>Faces and threats are worldbuilding first.</h2>
      <div class="card-grid">
        {featuredDossiers.map((page) => (
          <ShowcaseCard page={page} href={`${page.kind === 'monster' ? 'monsters' : 'characters'}/${page.slug}`} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
